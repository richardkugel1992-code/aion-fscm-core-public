# --- [ARCHITEKTUR & SICHERHEIT] ---
# Kritische Konfigurationen und Token
.env
.env.*
*.secret
*.key
*.pem
*.pfx
secrets.json
config.json
credentials.yaml

# Datenbanken & Persistent Data (Nicht ins Repo!)
*.db
*.sqlite
*.sqlite3
*.log

# --- [SYSTEM & IDE] ---
# Projekt-Einstellungen
.vscode/
.idea/
.DS_Store
Thumbs.db
Desktop.ini

# --- [PYTHON & KERNEL] ---
# Bytecode & Umgebung
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.venv/
.tox/
.pytest_cache/

# --- [DOKUMENTATION & BILDER] ---
# Nur Infrastruktur, keine proprietären Daten
# (Hier werden Bilder, die du nicht teilen willst, explizit ausgeschlossen)
private_data/
archive/
temp/
